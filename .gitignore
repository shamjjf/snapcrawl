# ── Dependencies ────────────────────────────────────────────────
# Single lockfile at root is tracked; installed modules are not.
node_modules/

# ── Environment / secrets (C-05: no secrets in version control) ──
.env
.env.*
!.env.example

# ── Build outputs ───────────────────────────────────────────────
# dist/ = apps/extension (CRXJS/Vite); .next/ + out/ = apps/web (Next.js)
dist/
.next/
out/
build/
*.tsbuildinfo
# Auto-generated by Next.js on build
next-env.d.ts

# ── Test output ─────────────────────────────────────────────────
# Playwright run artefacts (traces, screenshots, videos) — regenerated per run.
test-results/
playwright-report/
.playwright/

# ── Caches ──────────────────────────────────────────────────────
.vite/
.turbo/
.cache/
coverage/
.vitest/

# ── Logs ────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── OS / editor ─────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
*.swp
*~
