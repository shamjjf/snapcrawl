# Admin panel environment (Next.js). Copy to .env.local and adjust.
# These defaults are safe: the panel talks to the real API as-is, provided the
# backend is running (npm run dev:api).

# Base URL of the SnapCrawl backend API.
NEXT_PUBLIC_API_URL=http://localhost:4000

# Data source. Leave unset for the real API — that is the default.
#
# Set to `true` ONLY to demo the UI with no backend. Fixture mode serves invented
# projects, sessions and screenshots while auth and the dashboard stay real, so it
# looks like a working panel with plausible data rather than something obviously
# fake. A banner is pinned to every page while it is on; if you see that banner
# outside a deliberate UI demo, the numbers on screen are fiction.
#
# NEXT_PUBLIC_USE_FIXTURES=true
