# Admin panel environment (Next.js). Copy to .env.local and adjust.

# Base URL of the SnapCrawl backend API.
NEXT_PUBLIC_API_URL=http://localhost:4000

# Data source toggle for the panel.
#   true  (default) — run on typed fixtures from @snapcrawl/shared (no backend needed)
#   false           — call the real API endpoints
# Flip this to false once the backend projects/tokens endpoints are live.
NEXT_PUBLIC_USE_FIXTURES=true
