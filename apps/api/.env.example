# SnapCrawl API — copy to `.env` and adjust. The code defaults below already work
# for local dev, so a .env is optional.

PORT=4000

# CORS (FR-BE-074). Browser/admin-panel origin — used for all non-/ext routes.
WEB_ORIGIN=http://localhost:3000

# Chrome extension origin allowed on /ext/* only. Leave BLANK in dev to reflect
# any chrome-extension:// origin; set to the pinned extension id in prod, e.g.
# EXT_ORIGIN=chrome-extension://abcdefghijklmnopabcdefghijklmnop
EXT_ORIGIN=

# Local MongoDB (Windows service / docker-compose). 127.0.0.1 avoids IPv6 (::1)
# resolution issues on Windows.
MONGODB_URI=mongodb://127.0.0.1:27017/snapcrawl

# Dev-only. Use a strong secret from a secrets manager in production.
JWT_SECRET=dev-only-secret-change-me

# Bootstrap admin (FR-BE-001). Boot-time seeding is OPT-IN: without SEED_ADMIN
# the API creates no account, so no deployment ever gets a known default login.
# Leaving this on in dev seeds admin@snapcrawl.dev with a RANDOM password that
# is printed once to the log on first boot.
SEED_ADMIN=true
# Optional. Set BOTH to choose the credentials instead of generating them. In
# production they are REQUIRED whenever SEED_ADMIN=true — the API refuses to
# invent an admin password there. Preferred prod path is the explicit CLI:
#   SEED_ADMIN_EMAIL=… SEED_ADMIN_PASSWORD=… npm run seed:admin -w apps/api
# SEED_ADMIN_EMAIL=admin@snapcrawl.dev
# SEED_ADMIN_PASSWORD=

# Outbound email for password resets (FR-BE-005). Leave SMTP_HOST BLANK in dev:
# the message is written to the API log instead of sent, so the whole reset flow
# works without an SMTP server. In production an unset SMTP_HOST is a hard error
# rather than a silent downgrade — a "check your email" flow whose mail only
# reaches a log file is worse than one that fails loudly.
SMTP_HOST=
SMTP_PORT=587
# false = STARTTLS (port 587); true = implicit TLS (port 465).
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=SnapCrawl <no-reply@snapcrawl.dev>

# Email verification (FR-BE-008). OFF by default — a Could-priority gate that
# defaulted on would lock out every existing account and break the demo seed.
# When "true", registration no longer signs the user in: it emails a link, and
# login is refused until the address is confirmed.
REQUIRE_EMAIL_VERIFICATION=false
# Accounts created before this instant are grandfathered past the gate (they
# never had a link to click). Defaults to the feature's ship date; set an
# earlier ISO date to force even old accounts to verify.
# EMAIL_VERIFICATION_GRANDFATHER_BEFORE=2026-07-16T00:00:00Z

# Near-duplicate screenshot detection (FR-BE-043). Two captures of one UI state
# count as duplicates when their perceptual hashes differ by at most this many
# bits (0..64). Higher = more aggressive merging. Default 8.
NEAR_DUPLICATE_MAX_HAMMING=8

# S3 / object storage for screenshots (FR-BE-040/044, NFR-013). Local dev uses
# MinIO (docker-compose): path-style addressing against a custom endpoint. In
# prod, leave S3_ENDPOINT blank to use real AWS S3 and set real creds/region.
S3_ENDPOINT=http://127.0.0.1:9000
S3_REGION=us-east-1
S3_BUCKET=snapcrawl
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_FORCE_PATH_STYLE=true
