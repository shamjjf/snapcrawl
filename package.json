{
  "name": "snapcrawl",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "npm run dev -w apps/api",
    "dev:web": "npm run dev -w apps/web",
    "dev:ext": "npm run dev -w apps/extension",
    "dev": "concurrently -n api,web,ext -c blue,green,yellow \"npm:dev:api\" \"npm:dev:web\" \"npm:dev:ext\"",
    "infra:minio": "node scripts/dev-minio.mjs",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "e2e:pipeline": "node scripts/e2e-pipeline.mjs",
    "smoke:crawl": "node scripts/crawl-smoke.mjs",
    "build": "npm run build --workspaces --if-present"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
